# Copy to .env and fill in your values

# --- Provider selection ---
# Options: anthropic | openai | gemini | ollama
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0

# --- Model name (optional — defaults shown below) ---
# anthropic default: claude-sonnet-4-20250514
# openai    default: gpt-4o
# gemini    default: gemini-2.0-flash
# ollama    default: gemma3:12b  (no API key needed — runs locally)
MODEL_NAME=gemma3:12b

# --- API keys (only the one matching LLM_PROVIDER is required) ---
# ollama requires no API key
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# --- Ollama config (only when LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Pipeline config ---
MAX_FILE_SIZE_MB=150
TIER1_PERCENTILE=85
TIER2_PERCENTILE=50
