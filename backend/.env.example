# Copy to .env and fill in your values

# --- Provider selection ---
# Options: anthropic | openai | azure | gemini | ollama
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0

# --- Model name (optional — defaults shown below) ---
# anthropic default: claude-sonnet-4-20250514
# openai    default: gpt-4o
# azure     default: gpt-4o  (set to your Azure deployment name)
# gemini    default: gemini-2.0-flash
# ollama    default: gemma3:12b  (no API key needed — runs locally)
MODEL_NAME=gemma3:12b

# --- API keys (only the one matching LLM_PROVIDER is required) ---
# ollama requires no API key
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# --- Azure OpenAI / Azure AI Foundry (only when LLM_PROVIDER=azure) ---
# Endpoint:   Azure OpenAI resource URL, e.g. https://my-resource.openai.azure.com/
#             For Azure AI Foundry (Model Catalog), use the project endpoint shown
#             in AI Foundry → your project → Overview → "Azure OpenAI" target URI.
# API version: use the latest GA or preview version from:
#             https://learn.microsoft.com/azure/ai-services/openai/reference
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Ollama config (only when LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Pipeline config ---
MAX_FILE_SIZE_MB=150
TIER1_PERCENTILE=85
TIER2_PERCENTILE=50
